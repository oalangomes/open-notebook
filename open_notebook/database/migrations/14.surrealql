-- Migration 14: Podcast profiles model registry integration and Git sync state

-- EPISODE PROFILE
-- Legacy fields: make optional (app ignores, preserved for data migration)
DEFINE FIELD OVERWRITE outline_provider ON TABLE episode_profile TYPE option<string>;
DEFINE FIELD OVERWRITE outline_model ON TABLE episode_profile TYPE option<string>;
DEFINE FIELD OVERWRITE transcript_provider ON TABLE episode_profile TYPE option<string>;
DEFINE FIELD OVERWRITE transcript_model ON TABLE episode_profile TYPE option<string>;

-- New fields: reference to Model registry
DEFINE FIELD IF NOT EXISTS outline_llm ON TABLE episode_profile TYPE option<record<model>>;
DEFINE FIELD IF NOT EXISTS transcript_llm ON TABLE episode_profile TYPE option<record<model>>;
DEFINE FIELD IF NOT EXISTS language ON TABLE episode_profile TYPE option<string>;

-- SPEAKER PROFILE
-- Legacy fields: make optional
DEFINE FIELD OVERWRITE tts_provider ON TABLE speaker_profile TYPE option<string>;
DEFINE FIELD OVERWRITE tts_model ON TABLE speaker_profile TYPE option<string>;

-- New field: reference to Model registry (profile-level)
DEFINE FIELD IF NOT EXISTS voice_model ON TABLE speaker_profile TYPE option<record<model>>;

-- Per-speaker TTS override
DEFINE FIELD IF NOT EXISTS speakers.*.voice_model ON TABLE speaker_profile TYPE option<record<model>>;

-- GIT SYNC
DEFINE TABLE git_sync SCHEMAFULL;
DEFINE FIELD provider ON git_sync TYPE string;
DEFINE FIELD repo ON git_sync TYPE string;
DEFINE FIELD branch ON git_sync TYPE string;
DEFINE FIELD paths ON git_sync TYPE array DEFAULT [];
DEFINE FIELD paths.* ON git_sync TYPE string;
DEFINE FIELD credential_id ON git_sync TYPE string;
DEFINE FIELD notebooks ON git_sync TYPE array DEFAULT [];
DEFINE FIELD notebooks.* ON git_sync TYPE string;
DEFINE FIELD transformations ON git_sync TYPE array DEFAULT [];
DEFINE FIELD transformations.* ON git_sync TYPE string;
DEFINE FIELD embed ON git_sync TYPE bool DEFAULT false;
DEFINE FIELD refresh_interval ON git_sync TYPE option<string>;
DEFINE FIELD file_states ON git_sync TYPE array DEFAULT [];
DEFINE FIELD file_states.* ON git_sync TYPE object;
DEFINE FIELD last_sync ON git_sync TYPE option<datetime>;
DEFINE FIELD last_status ON git_sync TYPE option<string>;
DEFINE FIELD last_error ON git_sync TYPE option<string>;
DEFINE FIELD last_run_summary ON git_sync TYPE option<object>;
DEFINE FIELD created ON git_sync TYPE option<datetime> DEFAULT time::now();
DEFINE FIELD updated ON git_sync TYPE option<datetime> DEFAULT time::now();

DEFINE INDEX idx_git_sync_provider_repo_branch ON git_sync FIELDS provider, repo, branch;
